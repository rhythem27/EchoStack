# ==============================================================================
# EchoStack System Infrastructure Environment Configuration Template (.env.example)
# ==============================================================================

# --- General System Application Config ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=generate-a-secure-secret-key-for-jwt-signing-here

# --- PostgreSQL Transactional & pgvector Storage ---
POSTGRES_DB=echostack_db
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres_user:postgres_secure_password@postgres:5432/echostack_db

# --- In-Memory Redis Caching & Rate Limiting ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- Apache Kafka Distributed Broker ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INGESTION_TOPIC=document.ingestion.events
KAFKA_CONSUMER_GROUP=document_processors

# --- Apache Spark Data Analytics Config ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_EXECUTOR_MEMORY=4G
SPARK_DRIVER_MEMORY=2G

# --- Langflow Visual Agent Builder Config ---
LANGFLOW_PORT=7860
LANGFLOW_DATABASE_URL=postgresql://postgres_user:postgres_secure_password@postgres:5432/echostack_db

# --- Langfuse Agent Observability Tracing ---
LANGFUSE_PUBLIC_KEY=lf-pub-mockkey-xxxx-xxxx
LANGFUSE_SECRET_KEY=lf-sec-mockkey-xxxx-xxxx
LANGFUSE_HOST=http://langfuse-server:3000

# Langfuse Server Internal Auth & Salt (Must match Langfuse Container Requirements)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-nextauth-secret-string-here
SALT=generate-a-secure-salt-for-langfuse-here

# --- RAGFlow Parsing Engine Config ---
RAGFLOW_API_KEY=ragflow_admin_secret_token
RAGFLOW_HOST=http://ragflow:9380

# --- Speech-to-Speech Gemini Live Config ---
# Obtain from Google AI Studio / GCP Console
GEMINI_API_KEY=AIzaSyYourGeminiAPIKeyHere
GEMINI_LIVE_MODEL=gemini-2.0-flash-exp
